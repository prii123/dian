# Configuración del servidor
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
DEBUG=False

# Configuración de descarga
DOWNLOAD_BASE_FOLDER=./descargas

# Configuración de Playwright
BROWSER_HEADLESS=True
BROWSER_TIMEOUT=90000
DOWNLOAD_TIMEOUT=45000

# Configuración de la DIAN
DIAN_WAIT_AFTER_LOGIN=8000
DIAN_WAIT_AFTER_CLICK=2000
DIAN_WAIT_BETWEEN_DOWNLOADS=2000
DIAN_PAGINATION_WAIT=8000

# Límites
MAX_CONCURRENT_TASKS=3

# Logs
LOG_LEVEL=INFO
ENABLE_DEBUG_SCREENSHOTS=False

# Limpieza automática
AUTO_CLEANUP_ENABLED=False
AUTO_CLEANUP_DAYS=7

# CORS
CORS_ORIGINS=["*"]

# =====================================================
# Configuración de Base de Datos PostgreSQL
# =====================================================
DB_HOST=localhost
DB_PORT=5432
DB_USER=dian_user
DB_PASSWORD=dian_password
DB_NAME=dian_db
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_PRE_PING=True
DB_ECHO=False

# =====================================================
# Configuración de Seguridad y API Keys
# =====================================================
API_KEY_ENABLED=True

# IMPORTANTE: Cambia esta Master API Key en producción
# Esta key se usa para administrar otras API keys
MASTER_API_KEY=master_abc123def456_CHANGE_IN_PRODUCTION

API_KEY_HEADER_NAME=X-API-Key
API_KEY_LENGTH=32
